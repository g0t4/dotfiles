{
    "parser-directories": [
        "~/repos/github/g0t4",
        "~/repos/github/tree-sitter-grammars",
        "~/repos/github/tree-sitter"
    ],
    "theme": {
        "harmony_message_system": "#6986ff",
        "harmony_start_token": { "bold": true },
        "harmony_message_developer": "#6AC4EC",
        "harmony_message_user": "#a99fff",
        "harmony_message_assistant_analysis": "#FFC379",
        "harmony_message_assistant_commentary": "#f99fff",
        "harmony_message_tool_result": "#fdfd90",
        "harmony_message_assistant_final": "#ffffff",
        "harmony_message_prefill": { "color": 145, "underline": true },
        "is_json": "#c1c1c1",

        "qwen_message_system": { "color": "#ff6b6b", "bold": true },
        "qwen_message_developer": { "color": "#f7b267", "bold": true },
        "qwen_message_user": { "color": "#61afef" },
        "qwen_message_assistant": { "color": "#98c379" },
        "qwen_message_tool_response": { "color": "#c678dd" },
        "qwen_message_all_other_roles": { "color": "#7f848e", "italic": true },
        "qwen_think_reasoning": { "color": "#7f848e", "italic": true },
        "qwen_think_tag": { "color": "#7f848e", "bold": true },
        "qwen_fim_prefix_token": "#6986ff",
        "qwen_fim_prefix_contents": "#6986ff",
        "qwen_fim_suffix_token": "#4ade80",
        "qwen_fim_suffix_contents": "#4ade80",
        "qwen_fim_middle_token": "#ff7eb3",
        "qwen_fim_middle_contents": "#ff7eb3",
        "qwen_repo_name_token": "#ffe66d",
        "qwen_repo_name": { "color": "#ffe66d", "bold": true },
        "qwen_file_sep_token": "#89dceb",
        "qwen_file_path": { "color": "#89dceb", "bold": true, "underline": true },
        "qwen_file_contents": "#89dceb",

        "attribute": {
            "color": 124,
            "italic": true
        },
        "comment": {
            "color": 245,
            "italic": true
        },
        "constant": 94,
        "constant.builtin": {
            "bold": true,
            "color": 94
        },
        "constructor": 136,
        "embedded": null,
        "function": 26,
        "function.builtin": {
            "bold": true,
            "color": 26
        },
        "keyword": 56,
        "module": 136,
        "number": {
            "bold": true,
            "color": 94
        },
        "operator": {
            "bold": true,
            "color": 239
        },
        "property": 124,
        "property.builtin": {
            "bold": true,
            "color": 124
        },
        "punctuation": 239,
        "punctuation.bracket": 239,
        "punctuation.delimiter": 239,
        "punctuation.special": 239,
        "string": 28,
        "string.special": 30,
        "tag": 18,
        "type": 23,
        "type.builtin": {
            "bold": true,
            "color": 23
        },
        "variable": 252,
        "variable.builtin": {
            "bold": true,
            "color": 252
        },
        "variable.parameter": {
            "color": 252,
            "underline": true
        }
    }
}
